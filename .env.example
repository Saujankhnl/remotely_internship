# ============================================================
# Remotely Internship Platform - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file to version control!
# ============================================================

# ==================== DJANGO CORE ====================
DJANGO_SECRET_KEY=your-secret-key-here-generate-one-with-django-get-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ==================== DATABASE ====================
# Default: SQLite (no config needed for development)
# For PostgreSQL (production):
# DATABASE_URL=postgres://user:password@localhost:5432/remotely_db

# ==================== EMAIL (SendGrid) ====================
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@remotely.com

# ==================== SOCIAL AUTH (Google) ====================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==================== SOCIAL AUTH (LinkedIn) ====================
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ==================== CHANNELS (Production) ====================
# Required only for WebSocket chat in production
# REDIS_URL=redis://127.0.0.1:6379/0
